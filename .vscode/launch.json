{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Check environment",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/check_environment.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Run smoke test",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/smoke_test.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug current Python file",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
